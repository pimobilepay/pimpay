/**
 * .env.example - Updated with required security variables
 * [FIX V23-V29] Complete security configuration
 */

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pimpay

# Authentication
JWT_SECRET=your-super-secret-key-min-32-chars-required-!!!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-!!!!

# Encryption for private keys
ENCRYPTION_KEY=your-encryption-key-32-characters-long-!!!!

# CSRF Protection [FIX V25]
CSRF_SECRET=your-csrf-secret-key-min-32-chars-!!!!

# Redis for distributed rate limiting & token blacklist [FIX V23 + V28]
UPSTASH_REDIS_REST_URL=https://...-upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Firebase Configuration
FIREBASE_API_KEY=your-key
FIREBASE_AUTH_DOMAIN=your-domain
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-bucket
FIREBASE_MESSAGING_SENDER_ID=your-id
FIREBASE_APP_ID=your-app-id

# Blockchain RPC
SIDRA_RPC=https://node.sidrachain.com
XRP_RPC=https://xrpl.example.com

# External APIs
PROXYCHECK_API_KEY=your-key
CLOUDINARY_URL=cloudinary://key:secret@cloud-name
GOOGLE_GENAI_API_KEY=your-key

# Environment
NODE_ENV=production

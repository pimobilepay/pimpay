generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// EXISTING ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  FEE
  EXCHANGE
  CRYPTO_BUY
  CRYPTO_SELL
  CARD_PURCHASE
  CARD_TOPUP
  EXTERNAL_TRANSFER
  MOBILE_MONEY_IN
  MOBILE_MONEY_OUT
  BANK_TRANSFER_IN
  BANK_TRANSFER_OUT
  PI_PAYMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PROCESSING
  EXPIRED
  WAITING_APPROVAL
}

enum CurrencyType {
  XAF
  EUR
  USD
  BTC
  ETH
  USDT
  XLM
  PI
  XOF
  TRX
}

enum CardStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  EXPIRED
  PENDING
}

enum CardType {
  VIRTUAL
  PHYSICAL
  PREPAID
}

enum ExchangeStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  TRANSACTION
  SECURITY
  PROMOTION
  SYSTEM
  KYC
  REFERRAL
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ─────────────────────────────────────────────
// EXISTING MODELS
// ─────────────────────────────────────────────

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  phone                String?       @unique
  password             String
  firstName            String
  lastName             String
  username             String?       @unique
  avatar               String?
  role                 UserRole      @default(USER)
  kycStatus            KycStatus     @default(NONE)
  status               UserStatus    @default(ACTIVE)
  emailVerified        Boolean       @default(false)
  phoneVerified        Boolean       @default(false)
  twoFactorEnabled     Boolean       @default(false)
  twoFactorSecret      String?
  referralCode         String?       @unique
  referredBy           String?
  country              String?
  dateOfBirth          DateTime?
  address              String?
  city                 String?
  postalCode           String?
  nationality          String?
  occupation           String?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  wallets              Wallet[]
  transactions         Transaction[]
  notifications        Notification[]
  cards                Card[]
  referrals            Referral[]    @relation("UserReferrals")
  referredUsers        Referral[]    @relation("ReferredUsers")
  actionLogs           ActionLog[]
  bankAccounts         BankAccount[]
  mobileMoneyTransactions MobileMoneyTransaction[]
  externalBankTransfers   ExternalBankTransfer[]
  kycProfileRecords    KYCProfileRecord[]
  bnplPlans            BNPLPlan[]
  requestsToPay        RequestToPay[]        @relation("R2PRequester")
  requestsToPayReceived RequestToPay[]       @relation("R2PRecipient")
  scheduledPayments    ScheduledPaymentRecord[]
  multiSignatureConfigs MultiSignatureConfig[]
  multiSignatureApprovals MultiSignatureApproval[]
  portalUser           BankPortalUser?

  @@map("users")
}

model Wallet {
  id          String       @id @default(cuid())
  userId      String
  currency    CurrencyType
  balance     Decimal      @default(0) @db.Decimal(20, 8)
  lockedBalance Decimal    @default(0) @db.Decimal(20, 8)
  isActive    Boolean      @default(true)
  address     String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id])
  sentTransactions     Transaction[] @relation("SenderWallet")
  receivedTransactions Transaction[] @relation("ReceiverWallet")

  @@unique([userId, currency])
  @@index([userId])
  @@index([currency])
  @@map("wallets")
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  senderWalletId    String?
  receiverWalletId  String?
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  amount            Decimal           @db.Decimal(20, 8)
  fee               Decimal           @default(0) @db.Decimal(20, 8)
  currency          CurrencyType
  description       String?
  reference         String?           @unique
  metadata          Json?
  ipAddress         String?
  deviceId          String?
  failureReason     String?
  processedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id])
  senderWallet      Wallet?           @relation("SenderWallet", fields: [senderWalletId], references: [id])
  receiverWallet    Wallet?           @relation("ReceiverWallet", fields: [receiverWalletId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([reference])
  @@map("transactions")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  title     String
  body      String
  isRead    Boolean             @default(false)
  metadata  Json?
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

model Card {
  id             String       @id @default(cuid())
  userId         String
  type           CardType
  status         CardStatus   @default(PENDING)
  cardNumber     String?      @unique
  maskedNumber   String?
  expiryMonth    Int?
  expiryYear     Int?
  cvv            String?
  holderName     String
  currency       CurrencyType @default(XAF)
  balance        Decimal      @default(0) @db.Decimal(20, 8)
  spendingLimit  Decimal?     @db.Decimal(20, 8)
  isContactless  Boolean      @default(true)
  isOnlineEnabled Boolean     @default(true)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  cardTransactions CardTransaction[]

  @@index([userId])
  @@index([status])
  @@map("cards")
}

model CardTransaction {
  id              String            @id @default(cuid())
  cardId          String
  amount          Decimal           @db.Decimal(20, 8)
  currency        CurrencyType
  merchantName    String?
  merchantCode    String?
  merchantCountry String?
  status          TransactionStatus @default(PENDING)
  type            TransactionType
  reference       String?           @unique
  description     String?
  metadata        Json?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  card            Card              @relation(fields: [cardId], references: [id])

  @@index([cardId])
  @@index([status])
  @@index([createdAt])
  @@map("card_transactions")
}

model Exchange {
  id           String         @id @default(cuid())
  userId       String?
  fromCurrency CurrencyType
  toCurrency   CurrencyType
  fromAmount   Decimal        @db.Decimal(20, 8)
  toAmount     Decimal        @db.Decimal(20, 8)
  rate         Decimal        @db.Decimal(20, 8)
  fee          Decimal        @default(0) @db.Decimal(20, 8)
  status       ExchangeStatus @default(PENDING)
  reference    String?        @unique
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([fromCurrency, toCurrency])
  @@map("exchanges")
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  rewardAmount Decimal  @default(0) @db.Decimal(20, 8)
  currency     CurrencyType @default(XAF)
  isPaid       Boolean  @default(false)
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  referrer     User     @relation("UserReferrals", fields: [referrerId], references: [id])
  referred     User     @relation("ReferredUsers", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}

model Operator {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  country     String
  currency    CurrencyType
  isActive    Boolean  @default(true)
  apiEndpoint String?
  apiKey      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mobileMoneyProviders MobileMoneyProvider[]

  @@index([country])
  @@index([isActive])
  @@map("operators")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  category  String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("system_configs")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([email])
  @@map("contact_messages")
}

model ScheduledTask {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  cronExpr    String
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([nextRunAt])
  @@map("scheduled_tasks")
}

model ActionLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String?
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("action_logs")
}

model GlobalStats {
  id                 String   @id @default(cuid())
  totalUsers         Int      @default(0)
  activeUsers        Int      @default(0)
  totalTransactions  Int      @default(0)
  totalVolume        Decimal  @default(0) @db.Decimal(30, 8)
  totalFees          Decimal  @default(0) @db.Decimal(20, 8)
  totalCards         Int      @default(0)
  totalExchanges     Int      @default(0)
  date               DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([date])
  @@map("global_stats")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  resource   String?
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountName   String
  accountNumber String
  iban          String?
  swift         String?
  routingNumber String?
  country       String
  currency      CurrencyType
  isVerified    Boolean  @default(false)
  isPrimary     Boolean  @default(false)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  externalBankTransfers ExternalBankTransfer[]

  @@index([userId])
  @@index([country])
  @@map("bank_accounts")
}

model MobileMoneyProvider {
  id          String   @id @default(cuid())
  operatorId  String
  name        String
  code        String   @unique
  country     String
  currency    CurrencyType
  isActive    Boolean  @default(true)
  apiEndpoint String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  operator    Operator @relation(fields: [operatorId], references: [id])
  transactions MobileMoneyTransaction[]

  @@index([operatorId])
  @@index([country])
  @@index([isActive])
  @@map("mobile_money_providers")
}

model MobileMoneyTransaction {
  id           String         @id @default(cuid())
  userId       String
  providerId   String
  phone        String
  amount       Decimal        @db.Decimal(20, 8)
  fee          Decimal        @default(0) @db.Decimal(20, 8)
  currency     CurrencyType
  status       TransferStatus @default(PENDING)
  type         TransactionType
  reference    String?        @unique
  externalRef  String?
  description  String?
  metadata     Json?
  processedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id])
  provider     MobileMoneyProvider @relation(fields: [providerId], references: [id])

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([phone])
  @@index([createdAt])
  @@map("mobile_money_transactions")
}

model ExternalBankTransfer {
  id            String         @id @default(cuid())
  userId        String
  bankAccountId String
  amount        Decimal        @db.Decimal(20, 8)
  fee           Decimal        @default(0) @db.Decimal(20, 8)
  currency      CurrencyType
  status        TransferStatus @default(PENDING)
  type          TransactionType
  reference     String?        @unique
  externalRef   String?
  description   String?
  metadata      Json?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  bankAccount   BankAccount    @relation(fields: [bankAccountId], references: [id])

  @@index([userId])
  @@index([bankAccountId])
  @@index([status])
  @@index([createdAt])
  @@map("external_bank_transfers")
}

model FeeConfig {
  id             String       @id @default(cuid())
  name           String
  transactionType TransactionType
  flatFee        Decimal      @default(0) @db.Decimal(20, 8)
  percentageFee  Decimal      @default(0) @db.Decimal(10, 6)
  minFee         Decimal      @default(0) @db.Decimal(20, 8)
  maxFee         Decimal?     @db.Decimal(20, 8)
  currency       CurrencyType @default(XAF)
  isActive       Boolean      @default(true)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([transactionType])
  @@index([isActive])
  @@map("fee_configs")
}

model Fee {
  id            String            @id @default(cuid())
  transactionId String?
  amount        Decimal           @db.Decimal(20, 8)
  currency      CurrencyType
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  reference     String?           @unique
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([transactionId])
  @@index([status])
  @@index([type])
  @@map("fees")
}

// ─────────────────────────────────────────────
// NEW ENUMS
// ─────────────────────────────────────────────

enum BankAccountType {
  CACC
  BIZZ
  SVGS
  EWLT
  CWLT
  PIWT
  NSVR
}

enum ISO20022MessageType {
  PACS_008
  PACS_002
  PACS_004
  PACS_009
  PAIN_001
  PAIN_002
  CAMT_052
  CAMT_053
  CAMT_054
}

enum ISO20022MessageStatus {
  RECEIVED
  VALIDATED
  PROCESSING
  SETTLED
  REJECTED
  RETURNED
  PENDING_AUTH
}

enum PaymentType {
  CREDIT_TRANSFER
  RETURN
  FI_TRANSFER
  DIRECT_DEBIT
}

enum TransactionPriority {
  HIGH
  NORMAL
  LOW
}

enum ComplianceStatus {
  CLEAR
  FLAGGED
  BLOCKED
  UNDER_REVIEW
}

enum KYCTier {
  TIER_0
  TIER_1
  TIER_2
  TIER_3
}

enum BankPortalRole {
  PORTAL_SUPER_ADMIN
  PORTAL_ADMIN
  COMPLIANCE_OFFICER
  TREASURER
  OPERATOR_ROLE
  AUDITOR
  VIEWER
}

enum WebhookStatus {
  WH_ACTIVE
  WH_INACTIVE
  WH_FAILED
}

enum BNPLStatus {
  BNPL_ACTIVE
  BNPL_COMPLETED
  BNPL_DEFAULTED
  BNPL_CANCELLED
}

enum R2PStatus {
  R2P_PENDING
  R2P_ACCEPTED
  R2P_REJECTED
  R2P_EXPIRED
}

enum ScheduledPaymentStatus {
  SP_ACTIVE
  SP_PAUSED
  SP_COMPLETED
  SP_CANCELLED
}

enum SweepRuleType {
  THRESHOLD
  PERCENTAGE
  FIXED_AMOUNT
}

enum AMLAlertSeverity {
  SEV_LOW
  SEV_MEDIUM
  SEV_HIGH
  SEV_CRITICAL
}

// ─────────────────────────────────────────────
// NEW MODELS
// ─────────────────────────────────────────────

model ISO20022Message {
  id                 String                @id @default(cuid())
  messageId          String                @unique
  messageType        ISO20022MessageType
  messageStatus      ISO20022MessageStatus @default(RECEIVED)
  paymentType        PaymentType?
  senderBic          String?
  receiverBic        String?
  creationDateTime   DateTime
  settlementDate     DateTime?
  totalAmount        Decimal               @db.Decimal(20, 8)
  currency           CurrencyType
  numberOfTxns       Int                   @default(0)
  rawPayload         Json
  validationErrors   Json?
  processedAt        DateTime?
  settledAt          DateTime?
  rejectionReason    String?
  correlationId      String?
  instructionId      String?
  endToEndId         String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  paymentTransactions PaymentTransaction[]

  @@index([messageType])
  @@index([messageStatus])
  @@index([creationDateTime])
  @@index([senderBic])
  @@index([receiverBic])
  @@index([settlementDate])
  @@map("iso20022_messages")
}

model PaymentTransaction {
  id                  String               @id @default(cuid())
  isoMessageId        String?
  endToEndId          String               @unique
  instructionId       String?
  transactionId       String?              @unique
  paymentType         PaymentType
  priority            TransactionPriority  @default(NORMAL)
  status              ISO20022MessageStatus @default(RECEIVED)
  complianceStatus    ComplianceStatus     @default(CLEAR)
  debtorName          String
  debtorIban          String
  debtorBic           String?
  debtorAccountType   BankAccountType      @default(CACC)
  creditorName        String
  creditorIban        String
  creditorBic         String?
  creditorAccountType BankAccountType      @default(CACC)
  amount              Decimal              @db.Decimal(20, 8)
  currency            CurrencyType
  chargeBearer        String?              @default("SLEV")
  remittanceInfo      String?
  purposeCode         String?
  categoryPurpose     String?
  regulatoryReporting Json?
  settlementDate      DateTime?
  acceptanceDateTime  DateTime?
  processedAt         DateTime?
  rejectionReason     String?
  returnReason        String?
  originalTxId        String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isoMessage          ISO20022Message?     @relation(fields: [isoMessageId], references: [id])
  statusHistory       TransactionStatusHistory[]

  @@index([status])
  @@index([complianceStatus])
  @@index([debtorIban])
  @@index([creditorIban])
  @@index([settlementDate])
  @@index([createdAt])
  @@index([priority])
  @@map("payment_transactions")
}

model TransactionStatusHistory {
  id                   String               @id @default(cuid())
  paymentTransactionId String
  previousStatus       ISO20022MessageStatus?
  newStatus            ISO20022MessageStatus
  changedBy            String?
  reason               String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  paymentTransaction   PaymentTransaction   @relation(fields: [paymentTransactionId], references: [id])

  @@index([paymentTransactionId])
  @@index([createdAt])
  @@map("transaction_status_history")
}

model ISOBankAccount {
  id               String          @id @default(cuid())
  iban             String          @unique
  bban             String?
  bic              String?
  bankName         String
  accountHolderName String
  accountType      BankAccountType @default(CACC)
  currency         CurrencyType
  country          String
  isActive         Boolean         @default(true)
  isVerified       Boolean         @default(false)
  balance          Decimal         @default(0) @db.Decimal(20, 8)
  availableBalance Decimal         @default(0) @db.Decimal(20, 8)
  correspondentBankId String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  correspondentBank CorrespondentBank? @relation(fields: [correspondentBankId], references: [id])
  statementRecords BankStatementRecord[]

  @@index([bic])
  @@index([country])
  @@index([accountType])
  @@index([isActive])
  @@map("iso_bank_accounts")
}

model CorrespondentBank {
  id          String   @id @default(cuid())
  name        String
  bic         String   @unique
  country     String
  currency    CurrencyType
  isActive    Boolean  @default(true)
  nostroIban  String?
  vostroIban  String?
  apiEndpoint String?
  apiKey      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accounts    ISOBankAccount[]

  @@index([country])
  @@index([isActive])
  @@map("correspondent_banks")
}

model BankStatementRecord {
  id               String          @id @default(cuid())
  isoBankAccountId String
  statementId      String          @unique
  messageType      ISO20022MessageType
  fromDate         DateTime
  toDate           DateTime
  openingBalance   Decimal         @db.Decimal(20, 8)
  closingBalance   Decimal         @db.Decimal(20, 8)
  currency         CurrencyType
  numberOfEntries  Int             @default(0)
  totalDebit       Decimal         @default(0) @db.Decimal(20, 8)
  totalCredit      Decimal         @default(0) @db.Decimal(20, 8)
  entries          Json?
  rawPayload       Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isoBankAccount   ISOBankAccount  @relation(fields: [isoBankAccountId], references: [id])

  @@index([isoBankAccountId])
  @@index([fromDate, toDate])
  @@index([messageType])
  @@map("bank_statement_records")
}

model FXRate {
  id             String       @id @default(cuid())
  baseCurrency   CurrencyType
  quoteCurrency  CurrencyType
  rate           Decimal      @db.Decimal(20, 10)
  bidRate        Decimal?     @db.Decimal(20, 10)
  askRate        Decimal?     @db.Decimal(20, 10)
  source         String?
  validFrom      DateTime
  validTo        DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([baseCurrency, quoteCurrency, validFrom])
  @@index([baseCurrency, quoteCurrency])
  @@index([isActive])
  @@index([validFrom])
  @@map("fx_rates")
}

model KYCProfileRecord {
  id               String     @id @default(cuid())
  userId           String
  tier             KYCTier    @default(TIER_0)
  complianceStatus ComplianceStatus @default(CLEAR)
  riskScore        Int        @default(0)
  riskLevel        String?    @default("LOW")
  dailyLimit       Decimal    @default(0) @db.Decimal(20, 8)
  monthlyLimit     Decimal    @default(0) @db.Decimal(20, 8)
  singleTxnLimit   Decimal    @default(0) @db.Decimal(20, 8)
  pepFlag          Boolean    @default(false)
  sanctionFlag     Boolean    @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id])
  documents        KYCDocumentRecord[]
  verifications    KYCVerificationRecord[]

  @@index([userId])
  @@index([tier])
  @@index([complianceStatus])
  @@index([riskScore])
  @@map("kyc_profile_records")
}

model KYCDocumentRecord {
  id                String            @id @default(cuid())
  kycProfileId      String
  documentType      String
  documentNumber    String?
  issuingCountry    String?
  issuingAuthority  String?
  issueDate         DateTime?
  expiryDate        DateTime?
  frontImageUrl     String?
  backImageUrl      String?
  selfieImageUrl    String?
  isVerified        Boolean           @default(false)
  verificationScore Decimal?          @db.Decimal(5, 2)
  rejectionReason   String?
  verifiedAt        DateTime?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  kycProfile        KYCProfileRecord  @relation(fields: [kycProfileId], references: [id])

  @@index([kycProfileId])
  @@index([documentType])
  @@index([isVerified])
  @@map("kyc_document_records")
}

model KYCVerificationRecord {

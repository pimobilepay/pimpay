generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  phone               String?         @unique
  email               String?         @unique
  username            String?         @unique
  password            String?
  pin                 String?
  refreshToken        String?         @unique
  firstName           String?
  lastName            String?
  name                String?
  avatar              String?
  country             String?
  city                String?
  address             String?
  birthDate           DateTime?
  latitude            Float?
  longitude           Float?
  nationality         String?
  idType              String?
  idNumber            String?
  sourceOfFunds       String?
  kycFrontUrl         String?
  kycBackUrl          String?
  kycSelfieUrl        String?
  kycSubmittedAt      DateTime?
  kycVerifiedAt       DateTime?
  kycReason           String?
  referralCode        String?         @unique @default(cuid())
  referredById        String?
  dailyLimit          Float           @default(1000)
  monthlyLimit        Float           @default(10000)
  role                UserRole        @default(USER)
  kycStatus           KycStatus       @default(NONE)
  status              UserStatus      @default(ACTIVE)
  autoApprove         Boolean         @default(false)
  twoFactorEnabled    Boolean         @default(false)
  twoFactorSecret     String?
  failedLoginAttempts Int             @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  walletAddress       String?         @unique
  piUserId            String?         @unique
  countryOfBirth      String?
  gender              String?
  idCountry           String?
  idDeliveryDate      DateTime?
  idExpiryDate        DateTime?
  lastName2           String?
  middleName          String?
  nativeName          String?
  occupation          String?
  postalCode          String?
  provinceState       String?
  sidraAddress        String?         @unique
  sidraPrivateKey     String?
  stellarPrivateKey   String?
  walletPrivateKey    String?
  xlmAddress          String?         @unique
  xrpAddress          String?         @unique
  xrpPrivateKey       String?
  usdtAddress         String?         @unique
  usdtPrivateKey      String?
  solAddress          String?         @unique
  solPrivateKey       String?
  auditLogs           AuditLog[]      @relation("admin_actions")
  targetLogs          AuditLog[]      @relation("target_user")
  beneficiaries       Beneficiary[]
  merchantProfile     Merchant?       @relation("user_merchant")
  notifications       Notification[]
  qrPayments          QRPayment[]
  securityLogs        SecurityLog[]
  sessions            Session[]
  stakings            Staking[]
  supportTickets      SupportTicket[]
  swapQuotes          SwapQuote[]
  transactionsFrom    Transaction[]   @relation("tx_from_user")
  transactionsTo      Transaction[]   @relation("tx_to_user")
  referredBy          User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]          @relation("Referrals")
  userActivities      UserActivity[]
  vaults              Vault[]
  virtualCards        VirtualCard[]
  wallets             Wallet[]
  p2pContactsOwned    P2PContact[]    @relation("contact_owner")
  p2pContactsAsContact P2PContact[]   @relation("contact_user")
}

model P2PContact {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  name      String
  nickname  String?
  isFavorite Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("contact_owner", fields: [userId], references: [id], onDelete: Cascade)
  contact   User     @relation("contact_user", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId])
  @@index([isFavorite])
}

model Wallet {
  id               String        @id @default(cuid())
  userId           String
  balance          Float         @default(0)
  currency         String        @default("XAF")
  type             WalletType    @default(FIAT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  frozenBalance    Float         @default(0)
  depositMemo      String?       @unique
  transactionsFrom Transaction[] @relation("tx_from_wallet")
  transactionsTo   Transaction[] @relation("tx_to_wallet")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
  @@index([depositMemo])
}

model SwapQuote {
  id             String   @id @default(cuid())
  userId         String
  fromAmount     Float
  toAmount       Float
  rate           Float
  targetCurrency String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  sourceCurrency String   @default("USDT")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                 String    @id @default("GLOBAL_CONFIG")
  appVersion         String    @default("2.4.0")
  forceUpdate        Boolean   @default(false)
  globalAnnouncement String?
  maintenanceMode    Boolean   @default(false)
  maintenanceUntil   DateTime?
  transactionFee     Float     @default(0.01)
  minWithdrawal      Float     @default(1.0)
  maxWithdrawal      Float     @default(5000.0)
  consensusPrice     Float    @default(314159.0)
  stakingAPY         Float     @default(15.0)
  totalProfit        Float     @default(0.0)
  updatedAt          DateTime  @updatedAt
  lastBackupAt       DateTime  @default(now())
  totalUsers         Int       @default(0)
  totalVolumePi      Float     @default(0.0)
  comingSoonMode     Boolean   @default(false)
  withdrawFee        Float     @default(0.02)
  depositMobileFee   Float     @default(0.02)
  depositCardFee     Float     @default(0.035)
  exchangeFee        Float     @default(0.001)
  cardPaymentFee     Float     @default(0.015)
  transferFee        Float     @default(0.01)
  depositCryptoFee   Float     @default(0.01)
  withdrawMobileFee  Float     @default(0.025)
  withdrawBankFee    Float     @default(0.02)
  merchantPaymentFee Float     @default(0.02)
  billPaymentFee     Float     @default(0.015)
  qrPaymentFee       Float     @default(0.01)
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique @default(now())
  totalUsers     Int      @default(0)
  totalVolume    Float    @default(0.0)
  consensusPrice Float    @default(0.0)
  stakingAPY     Float    @default(0.0)
  activeUsers    Int      @default(0)
}

model Vault {
  id           String    @id @default(cuid())
  userId       String
  name         String
  amount       Float     @default(0)
  targetAmount Float?
  interestRate Float     @default(0)
  lockUntil    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Staking {
  id            String    @id @default(cuid())
  userId        String
  amount        Float
  apy           Float
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)
  rewardsEarned Float     @default(0)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Beneficiary {
  id           String   @id @default(cuid())
  userId       String
  name         String
  accountInfo  String
  provider     String
  createdAt    DateTime @default(now())
  email        String?
  firstname    String?
  lastname     String?
  msisdn       String?
  relationship String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(cuid())
  reference       String            @unique
  blockchainTx    String?           @unique
  amount          Float
  fee             Float             @default(0)
  netAmount       Float?
  status          TransactionStatus @default(PENDING)
  description     String?
  note            String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  fromUserId      String?
  fromWalletId    String?
  toUserId        String?
  toWalletId      String?
  qrPaymentId     String?
  accountName     String?
  accountNumber   String?
  bankBic         String?
  countryCode     String?
  currency        String            @default("XAF")
  destCurrency    String?
  externalId      String?           @unique
  operatorId      String?
  purpose         String?
  retailFee       Float?
  retailRate      Float?
  statusClass     String?
  wholesaleFxRate Float?
  type            TransactionType   @default(TRANSFER)
  fromUser        User?             @relation("tx_from_user", fields: [fromUserId], references: [id])
  fromWallet      Wallet?           @relation("tx_from_wallet", fields: [fromWalletId], references: [id])
  qrPayment       QRPayment?        @relation(fields: [qrPaymentId], references: [id])
  toUser          User?             @relation("tx_to_user", fields: [toUserId], references: [id])
  toWallet        Wallet?           @relation("tx_to_wallet", fields: [toWalletId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([reference])
  @@index([externalId])
}

model Merchant {
  id              String   @id @default(cuid())
  userId          String?  @unique
  name            String
  description     String?
  category        String
  address         String
  city            String
  country         String
  latitude        Float
  longitude       Float
  piPaymentStatus String   @default("ACCEPTED")
  rating          Float    @default(0.0)
  logoUrl         String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation("user_merchant", fields: [userId], references: [id])
}

model VirtualCard {
  id                String   @id @default(cuid())
  userId            String
  type              CardType @default(CLASSIC)
  number            String   @unique
  exp               String
  cvv               String?
  holder            String
  brand             String   @default("VISA")
  cardPin           String?
  isFrozen          Boolean  @default(false)
  dailyLimit        Float    @default(1000)
  totalSpent        Float    @default(0)
  allowedCurrencies String[] @default(["USD", "XAF"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QRPayment {
  id           String        @id @default(cuid())
  userId       String
  amount       Float?
  currency     String        @default("XAF")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ip           String?
  userAgent    String?
  deviceName   String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  browser      String?
  city         String?
  country      String?
  lat          Float?
  lon          Float?
  os           String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  code       String
  type       String   @default("VERIFICATION")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  adminName   String?
  action      String
  targetId    String?
  targetEmail String?
  details     String?
  createdAt   DateTime @default(now())
  admin       User?    @relation("admin_actions", fields: [adminId], references: [id])
  target      User?    @relation("target_user", fields: [targetId], references: [id])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ip        String?
  device    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  page      String
  action    String   @default("PAGE_VIEW")
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  duration  Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([page])
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String?
  subject   String
  status    SupportStatus @default(OPEN)
  priority  String        @default("MEDIUM")
  createdAt DateTime      @default(now())
  messages  Message[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum CardType {
  CLASSIC
  GOLD
  BUSINESS
  ULTRA
}

enum UserRole {
  ADMIN
  USER
  MERCHANT
  AGENT
  BANK_ADMIN
  BUSINESS_ADMIN
}

// ==================== BANK INSTITUTION ====================

enum BankStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
  INACTIVE
}

enum BankType {
  CENTRAL_BANK
  COMMERCIAL_BANK
  MICROFINANCE
  CREDIT_UNION
}

model Bank {
  id                  String       @id @default(cuid())
  name                String       @unique
  code                String       @unique // Code bancaire unique (ex: BEAC, BGFI)
  type                BankType     @default(COMMERCIAL_BANK)
  status              BankStatus   @default(PENDING_APPROVAL)
  
  // Informations de contact
  email               String?
  phone               String?
  address             String?
  city                String?
  country             String       @default("CG")
  
  // Informations legales
  licenseNumber       String?      @unique
  swiftCode           String?      @unique
  registrationNumber  String?
  
  // Limites et configuration
  dailyTransferLimit  Float        @default(100000000)
  monthlyTransferLimit Float       @default(1000000000)
  transactionFee      Float        @default(0.01)
  
  // Reserve et liquidite
  reserveBalance      Float        @default(0)
  minReserveRatio     Float        @default(0.15) // 15% minimum
  
  // Conformite
  kycVerified         Boolean      @default(false)
  amlCompliant        Boolean      @default(false)
  lastAuditDate       DateTime?
  
  // Metadata
  logoUrl             String?
  description         String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  
  // Relations
  administrators      BankAdmin[]
  interbankTransfers  InterbankTransfer[] @relation("from_bank")
  receivedTransfers   InterbankTransfer[] @relation("to_bank")
  complianceReports   BankComplianceReport[]
  alerts              BankAlert[]

  @@index([code])
  @@index([status])
}

model BankAdmin {
  id          String   @id @default(cuid())
  userId      String   @unique
  bankId      String
  role        String   @default("OPERATOR") // OPERATOR, MANAGER, DIRECTOR
  permissions String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([userId])
}

model InterbankTransfer {
  id              String            @id @default(cuid())
  reference       String            @unique
  fromBankId      String
  toBankId        String
  amount          Float
  currency        String            @default("XAF")
  fee             Float             @default(0)
  status          TransactionStatus @default(PENDING)
  type            String            @default("SWIFT") // SWIFT, RTGS, ACH
  purpose         String?
  description     String?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  
  fromBank        Bank              @relation("from_bank", fields: [fromBankId], references: [id])
  toBank          Bank              @relation("to_bank", fields: [toBankId], references: [id])

  @@index([fromBankId])
  @@index([toBankId])
  @@index([reference])
}

model BankComplianceReport {
  id          String   @id @default(cuid())
  bankId      String
  type        String   // KYC_AUDIT, AML_REPORT, REGULATORY_FILING
  period      String   // Q1_2026, MONTHLY_03_2026
  status      String   @default("PENDING") // PENDING, SUBMITTED, APPROVED, REJECTED
  findings    Json?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([type])
}

model BankAlert {
  id          String   @id @default(cuid())
  bankId      String
  type        String   // SECURITY, COMPLIANCE, TRANSACTION, SYSTEM
  severity    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title       String
  message     String
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([severity])
  @@index([isResolved])
}

// ==================== BUSINESS INSTITUTION ====================

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  INACTIVE
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  LLC
  COOPERATIVE
  NGO
}

enum BusinessCategory {
  RETAIL
  WHOLESALE
  SERVICES
  MANUFACTURING
  TECHNOLOGY
  HOSPITALITY
  HEALTHCARE
  EDUCATION
  TRANSPORT
  AGRICULTURE
  OTHER
}

model Business {
  id                  String           @id @default(cuid())
  name                String
  tradeName           String?          // Nom commercial
  registrationNumber  String           @unique
  taxId               String?          @unique
  type                BusinessType     @default(SOLE_PROPRIETORSHIP)
  category            BusinessCategory @default(OTHER)
  status              BusinessStatus   @default(PENDING_VERIFICATION)
  
  // Informations de contact
  email               String?
  phone               String?
  website             String?
  address             String?
  city                String?
  country             String           @default("CG")
  postalCode          String?
  
  // Informations bancaires
  bankAccountNumber   String?
  bankName            String?
  bankCode            String?
  
  // Limites et configuration
  dailyTransactionLimit  Float         @default(10000000)
  monthlyTransactionLimit Float        @default(100000000)
  paymentFeeRate      Float            @default(0.02) // 2%
  
  // Verification
  isVerified          Boolean          @default(false)
  verifiedAt          DateTime?
  kycStatus           KycStatus        @default(NONE)
  
  // Documents
  logoUrl             String?
  documentUrls        String[]         @default([])
  
  // Stats
  totalRevenue        Float            @default(0)
  totalTransactions   Int              @default(0)
  
  // Metadata
  description         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  
  // Relations
  administrators      BusinessAdmin[]
  employees           BusinessEmployee[]
  payments            BusinessPayment[]
  invoices            BusinessInvoice[]
  products            BusinessProduct[]

  @@index([registrationNumber])
  @@index([status])
  @@index([category])
}

model BusinessAdmin {
  id          String   @id @default(cuid())
  userId      String   @unique
  businessId  String
  role        String   @default("MANAGER") // OWNER, MANAGER, ACCOUNTANT
  permissions String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model BusinessEmployee {
  id          String   @id @default(cuid())
  businessId  String
  firstName   String
  lastName    String
  email       String?
  phone       String?
  position    String?
  department  String?
  salary      Float?
  hireDate    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model BusinessPayment {
  id              String            @id @default(cuid())
  reference       String            @unique
  businessId      String
  amount          Float
  currency        String            @default("XAF")
  fee             Float             @default(0)
  status          TransactionStatus @default(PENDING)
  type            String            @default("SALE") // SALE, REFUND, SUBSCRIPTION
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  description     String?
  metadata        Json?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  
  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([reference])
  @@index([status])
}

model BusinessInvoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  businessId      String
  customerName    String
  customerEmail   String?
  customerPhone   String?
  customerAddress String?
  items           Json     // Array of { description, quantity, unitPrice, total }
  subtotal        Float
  taxRate         Float    @default(0.18) // 18% TVA
  taxAmount       Float
  total           Float
  status          String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  dueDate         DateTime?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

model BusinessProduct {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  sku         String?
  price       Float
  currency    String   @default("XAF")
  stock       Int      @default(0)
  category    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([category])
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
  FROZEN
  SUSPENDED
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
  APPROVED
}

enum WalletType {
  PI
  FIAT
  CRYPTO
  SIDRA
}

enum TransactionType {
  TRANSFER
  WITHDRAW
  DEPOSIT
  PAYMENT
  EXCHANGE
  STAKING_REWARD
  AIRDROP
  CARD_PURCHASE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  source    String   // ex: "API", "WORKER", "AUTH", "PAYMENT"
  action    String   // ex: "TRANSFER_FAILED", "LOGIN_ERROR", "WORKER_TIMEOUT"
  message   String
  details   Json?    // stack trace, request data, etc.
  ip        String?
  userAgent String?
  userId    String?  // optional link to user if relevant
  requestId String?  // for tracing requests
  duration  Int?     // execution time in ms
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([userId])
}

enum KYCTier {
  TIER_0
  TIER_1
  TIER_2
  TIER_3
}

enum BankPortalRole {
  PORTAL_SUPER_ADMIN
  PORTAL_ADMIN
  COMPLIANCE_OFFICER
  TREASURER
  OPERATOR_ROLE
  AUDITOR
  VIEWER
}

enum WebhookStatus {
  WH_ACTIVE
  WH_INACTIVE
  WH_FAILED
}

enum BNPLStatus {
  BNPL_ACTIVE
  BNPL_COMPLETED
  BNPL_DEFAULTED
  BNPL_CANCELLED
}

enum R2PStatus {
  R2P_PENDING
  R2P_ACCEPTED
  R2P_REJECTED
  R2P_EXPIRED
}

enum ScheduledPaymentStatus {
  SP_ACTIVE
  SP_PAUSED
  SP_COMPLETED
  SP_CANCELLED
}

enum SweepRuleType {
  THRESHOLD
  PERCENTAGE
  FIXED_AMOUNT
}

enum AMLAlertSeverity {
  SEV_LOW
  SEV_MEDIUM
  SEV_HIGH
  SEV_CRITICAL
}

enum BankStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
  INACTIVE
}

enum BankType {
  CENTRAL_BANK
  COMMERCIAL_BANK
  MICROFINANCE
  CREDIT_UNION
}

enum BusinessCategory {
  RETAIL
  WHOLESALE
  SERVICES
  MANUFACTURING
  TECHNOLOGY
  HOSPITALITY
  HEALTHCARE
  EDUCATION
  TRANSPORT
  AGRICULTURE
  OTHER
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  INACTIVE
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  LLC
  COOPERATIVE
  NGO
}

enum LoanStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  ACTIVE
  COMPLETED
  DEFAULTED
  REJECTED
  CANCELLED
}

enum LoanType {
  PERSONAL
  BUSINESS
  MORTGAGE
  AUTO
  EDUCATION
  AGRICULTURE
  EMERGENCY
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  MISSED
  PARTIAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum SavingsStatus {
  ACTIVE
  MATURED
  CLOSED
  FROZEN
}

enum SavingsType {

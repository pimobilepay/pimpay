generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id @default(cuid())
  phone                String?          @unique
  email                String?          @unique
  username             String?          @unique
  password             String?
  pin                  String?
  refreshToken         String?          @unique
  firstName            String?
  lastName             String?
  name                 String?
  avatar               String?
  country              String?
  city                 String?
  address              String?
  birthDate            DateTime?
  latitude             Float?
  longitude            Float?
  nationality          String?
  idType               String?
  idNumber             String?
  sourceOfFunds        String?
  kycFrontUrl          String?
  kycBackUrl           String?
  kycSelfieUrl         String?
  kycSubmittedAt       DateTime?
  kycVerifiedAt        DateTime?
  kycReason            String?
  referralCode         String?          @unique @default(cuid())
  agentId              String?          @unique
  referredById         String?
  dailyLimit           Float            @default(1000)
  monthlyLimit         Float            @default(10000)
  role                 UserRole         @default(USER)
  kycStatus            KycStatus        @default(NONE)
  status               UserStatus       @default(ACTIVE)
  autoApprove          Boolean          @default(false)
  twoFactorEnabled     Boolean          @default(false)
  twoFactorSecret      String?
  failedLoginAttempts  Int              @default(0)
  lockedUntil          DateTime?
  mustChangePassword   Boolean          @default(false)
  lastLoginAt          DateTime?
  lastLoginIp          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  walletAddress        String?          @unique
  piUserId             String?          @unique
  countryOfBirth       String?
  gender               String?
  idCountry            String?
  idDeliveryDate       DateTime?
  idExpiryDate         DateTime?
  lastName2            String?
  middleName           String?
  nativeName           String?
  occupation           String?
  postalCode           String?
  provinceState        String?
  sidraAddress         String?          @unique
  sidraPrivateKey      String?
  stellarPrivateKey    String?
  walletPrivateKey     String?
  xlmAddress           String?          @unique
  xrpAddress           String?          @unique
  xrpPrivateKey        String?
  usdtAddress          String?          @unique
  usdtPrivateKey       String?
  solAddress           String?          @unique
  solPrivateKey        String?
  pinUpdatedAt         DateTime?
  pinVersion           Int              @default(1)
  statusReason         String?
  maintenanceUntil     DateTime?
  agentRole            AgentRole?       @default(AGENT)
  emailVerified        DateTime?
  accounts             Account[]
  adminProfile         AdminProfile?    @relation("user_admin_profile")
  auditLogs            AuditLog[]       @relation("admin_actions")
  targetLogs           AuditLog[]       @relation("target_user")
  beneficiaries        Beneficiary[]
  creditScore          CreditScore?
  loans                Loan[]
  merchantProfile      Merchant?        @relation("user_merchant")
  notifications        Notification[]
  p2pContactsAsContact P2PContact[]     @relation("contact_user")
  p2pContactsOwned     P2PContact[]     @relation("contact_owner")
  qrPayments           QRPayment[]
  savingsAccounts      SavingsAccount[]
  securityLogs         SecurityLog[]
  sessions             Session[]
  stakings             Staking[]
  supportTickets       SupportTicket[]
  swapQuotes           SwapQuote[]
  transactionsFrom     Transaction[]    @relation("tx_from_user")
  transactionsTo       Transaction[]    @relation("tx_to_user")
  referredBy           User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals            User[]           @relation("Referrals")
  userActivities       UserActivity[]
  vaults               Vault[]
  virtualCards         VirtualCard[]
  wallets              Wallet[]
}

model P2PContact {
  id         String   @id @default(cuid())
  userId     String
  contactId  String
  name       String
  nickname   String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  contact    User     @relation("contact_user", fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation("contact_owner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, contactId])
  @@index([userId])
  @@index([isFavorite])
  @@index([contactId])
}

model Wallet {
  id               String        @id @default(cuid())
  userId           String
  balance          Float         @default(0)
  currency         String        @default("XAF")
  type             WalletType    @default(FIAT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  frozenBalance    Float         @default(0)
  depositMemo      String?       @unique
  transactionsFrom Transaction[] @relation("tx_from_wallet")
  transactionsTo   Transaction[] @relation("tx_to_wallet")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
  @@index([depositMemo])
}

model SwapQuote {
  id             String   @id @default(cuid())
  userId         String
  fromAmount     Float
  toAmount       Float
  rate           Float
  targetCurrency String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  sourceCurrency String   @default("USDT")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                   String    @id @default("GLOBAL_CONFIG")
  piNetwork            String    @default("testnet")
  appVersion           String    @default("2.4.0")
  forceUpdate          Boolean   @default(false)
  globalAnnouncement   String?
  announcementImage    String?
  announcementLink     String?
  maintenanceMode      Boolean   @default(false)
  maintenanceUntil     DateTime?
  transactionFee       Float     @default(0.01)
  minWithdrawal        Float     @default(1.0)
  maxWithdrawal        Float     @default(5000.0)
  consensusPrice       Float     @default(314159.0)
  priceMode            String    @default("GCV")
  stakingAPY           Float     @default(15.0)
  totalProfit          Float     @default(0.0)
  updatedAt            DateTime  @updatedAt
  lastBackupAt         DateTime  @default(now())
  totalUsers           Int       @default(0)
  totalVolumePi        Float     @default(0.0)
  comingSoonMode       Boolean   @default(false)
  comingSoonUntil      DateTime?
  withdrawFee          Float     @default(0.02)
  depositMobileFee     Float     @default(0.02)
  depositCardFee       Float     @default(0.035)
  exchangeFee          Float     @default(0.001)
  cardPaymentFee       Float     @default(0.015)
  transferFee          Float     @default(0.01)
  depositCryptoFee     Float     @default(0.01)
  withdrawMobileFee    Float     @default(0.025)
  withdrawBankFee      Float     @default(0.02)
  merchantPaymentFee   Float     @default(0.02)
  billPaymentFee       Float     @default(0.015)
  qrPaymentFee         Float     @default(0.01)
  fiatTransferFee      Float     @default(0.005)
  referralBonus        Float     @default(0.0000318)
  referralWelcomeBonus Float     @default(0.0000159)
  maxLoginAttempts     Int       @default(5)
  lockoutDuration      Int       @default(30)
  sessionTimeout       Int       @default(60)
  // [IDS] Détection & défense contre proxy / VPN / Tor / datacenter
  proxyDetectionEnabled Boolean  @default(true)
  proxyDetectionMode    String   @default("BLOCK") // BLOCK | MONITOR
  blockVpn              Boolean  @default(true)
  blockProxy            Boolean  @default(true)
  blockTor              Boolean  @default(true)
  blockDatacenter       Boolean  @default(false)
  blockBots             Boolean  @default(false) // bots / scrapers / outils automatisés (User-Agent)
  blockHeaderSpoof      Boolean  @default(false) // en-têtes proxy falsifiés / chaînage anormal
  riskScoreThreshold    Int      @default(75) // 0-100, au-delà = blocage (75 = équilibré, anti faux positifs)
  ipWhitelist           String?  // IP/CIDR de confiance, séparés par virgule
  autoBlockOnDetection  Boolean  @default(false) // ajoute l'IP à la liste noire
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique @default(now())
  totalUsers     Int      @default(0)
  totalVolume    Float    @default(0.0)
  consensusPrice Float    @default(0.0)
  stakingAPY     Float    @default(0.0)
  activeUsers    Int      @default(0)
}

model Vault {
  id           String    @id @default(cuid())
  userId       String
  name         String
  amount       Float     @default(0)
  targetAmount Float?
  interestRate Float     @default(0)
  lockUntil    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Staking {
  id            String    @id @default(cuid())
  userId        String
  amount        Float
  apy           Float
  currency      String    @default("PI")
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)
  rewardsEarned Float     @default(0)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Beneficiary {
  id           String   @id @default(cuid())
  userId       String
  name         String
  accountInfo  String
  provider     String
  createdAt    DateTime @default(now())
  email        String?
  firstname    String?
  lastname     String?
  msisdn       String?
  relationship String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(cuid())
  reference       String            @unique
  blockchainTx    String?           @unique
  amount          Float
  fee             Float             @default(0)
  netAmount       Float?
  status          TransactionStatus @default(PENDING)
  description     String?
  note            String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  fromUserId      String?
  fromWalletId    String?
  toUserId        String?
  toWalletId      String?
  qrPaymentId     String?
  accountName     String?
  accountNumber   String?
  bankBic         String?
  countryCode     String?
  currency        String            @default("XAF")
  destCurrency    String?
  externalId      String?           @unique
  operatorId      String?
  purpose         String?
  retailFee       Float?
  retailRate      Float?
  statusClass     String?
  wholesaleFxRate Float?
  type            TransactionType   @default(TRANSFER)
  fromUser        User?             @relation("tx_from_user", fields: [fromUserId], references: [id])
  fromWallet      Wallet?           @relation("tx_from_wallet", fields: [fromWalletId], references: [id])
  qrPayment       QRPayment?        @relation(fields: [qrPaymentId], references: [id])
  toUser          User?             @relation("tx_to_user", fields: [toUserId], references: [id])
  toWallet        Wallet?           @relation("tx_to_wallet", fields: [toWalletId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([reference])
  @@index([externalId])
}

model Merchant {
  id              String   @id @default(cuid())
  userId          String?  @unique
  name            String
  description     String?
  category        String
  address         String
  city            String
  country         String
  latitude        Float
  longitude       Float
  piPaymentStatus String   @default("ACCEPTED")
  rating          Float    @default(0.0)
  logoUrl         String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation("user_merchant", fields: [userId], references: [id])
}

model VirtualCard {
  id                String   @id @default(cuid())
  userId            String
  type              CardType @default(CLASSIC)
  number            String   @unique
  exp               String
  cvv               String?
  holder            String
  brand             String   @default("VISA")
  cardPin           String?
  isFrozen          Boolean  @default(false)
  dailyLimit        Float    @default(1000)
  totalSpent        Float    @default(0)
  allowedCurrencies String[] @default(["USD", "XAF"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  balanceUSD        Float    @default(0)
  balanceEUR        Float    @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QRPayment {
  id           String        @id @default(cuid())
  userId       String
  amount       Float?
  currency     String        @default("XAF")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ip           String?
  userAgent    String?
  deviceName   String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  browser      String?
  city         String?
  country      String?
  lat          Float?
  lon          Float?
  os           String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  code       String
  type       String   @default("VERIFICATION")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  adminName   String?
  action      String
  targetId    String?
  targetEmail String?
  details     String?
  // Champs enrichis pour la traçabilité RBAC (optionnels, rétro-compatibles)
  category    String?  // users | finance | security | system | kyc | support | rbac...
  targetType  String?  // user | transaction | ip | config...
  ip          String?
  userAgent   String?
  status      String   @default("SUCCESS") // SUCCESS | DENIED | FAILED
  createdAt   DateTime @default(now())
  admin       User?    @relation("admin_actions", fields: [adminId], references: [id])
  target      User?    @relation("target_user", fields: [targetId], references: [id])

  @@index([adminId])
  @@index([category])
  @@index([action])
  @@index([createdAt])
}

// Profil RBAC d'un administrateur : permissions granulaires + statut super-admin.
// IMPORTANT (rétro-compatibilité) : un User role=ADMIN SANS AdminProfile est
// traité comme SUPER-ADMIN (accès total), pour ne casser aucun accès existant.
model AdminProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  isSuperAdmin Boolean  @default(false)
  permissions  String[] @default([])
  title        String?  // ex: "Analyste conformité", "Support N2"...
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("user_admin_profile", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ip        String?
  device    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  page      String
  action    String   @default("PAGE_VIEW")
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  host      String?
  origin    String?
  duration  Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([page])
  @@index([host])
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String?
  subject   String
  status    SupportStatus @default(OPEN)
  priority  String        @default("MEDIUM")
  createdAt DateTime      @default(now())
  messages  Message[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Trace des visiteurs NON connectés (mode invité), notamment sur la page de
// chat Elara. Permet de savoir qu'un invité est passé sur la plateforme même
// s'il n'a jamais envoyé de message. Identifié par le cookie invité opaque.
model GuestSession {
  id          String   @id @default(cuid())
  guestId     String   @unique
  ip          String?
  userAgent   String?
  device      String?
  browser     String?
  os          String?
  country     String?
  city        String?
  page        String?
  host        String?
  origin      String?
  referrer    String?
  visitCount  Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@index([guestId])
  @@index([lastSeenAt])
}

model Message {
  id          String        @id @default(cuid())
  ticketId    String
  senderId    String
  content     String
  createdAt   DateTime      @default(now())
  // Accuses de reception facon WhatsApp :
  //  - deliveredAt : le destinataire a recu le message (2 coches grises)
  //  - readAt      : le destinataire a ouvert/lu le message (2 coches bleues)
  // Les deux nuls => message simplement envoye (1 coche grise).
  deliveredAt DateTime?
  readAt      DateTime?
  // Reactions emoji facon WhatsApp : tableau JSON de { emoji, by }.
  // `by` = identifiant du reacteur (userId, guestId ou "SUPPORT").
  // Une personne ne peut avoir qu'une seule reaction par message.
  reactions   Json?
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  }

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Bank {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  type        BankType    @default(COMMERCIAL_BANK)
  status      BankStatus  @default(PENDING_APPROVAL)
  email       String?
  country     String      @default("CG")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  city        String?
  description String?
  address     String?
  phone       String?
  logo        String?
  BankAdmin   BankAdmin[]
  BankAlert   BankAlert[]
}

model Business {
  id                    String                   @id @default(cuid())
  name                  String
  registrationNumber    String                   @unique
  type                  BusinessType             @default(SOLE_PROPRIETORSHIP)
  category              BusinessCategory         @default(OTHER)
  status                BusinessStatus           @default(PENDING_VERIFICATION)
  country               String                   @default("CG")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @default(now()) @updatedAt
  city                  String?
  description           String?
  email                 String?
  phone                 String?
  logo                  String?
  BusinessEmployee      BusinessEmployee[]
  BusinessInvoice       BusinessInvoice[]
  BusinessBankAccount   BusinessBankAccount[]
  BusinessBankStatement BusinessBankStatement[]
}

model BusinessBankAccount {
  id         String                  @id @default(cuid())
  businessId String
  bankName   String
  name       String
  number     String
  balance    Float                   @default(0)
  currency   String                  @default("XAF")
  status     String                  @default("active")
  color      String                  @default("#6366f1")
  lastSync   DateTime                @default(now())
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @default(now()) @updatedAt
  Business   Business                @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Statements BusinessBankStatement[]

  @@index([businessId])
}

model BusinessBankStatement {
  id          String               @id @default(cuid())
  accountId   String
  businessId  String
  date        DateTime             @default(now())
  description String
  debit       Float                @default(0)
  credit      Float                @default(0)
  balance     Float                @default(0)
  reference   String
  createdAt   DateTime             @default(now())
  Account     BusinessBankAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([accountId])
  @@index([businessId])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  source    String
  action    String
  message   String
  details   Json?
  ip        String?
  userAgent String?
  userId    String?
  requestId String?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([userId])
}

// Liste noire d'adresses IP — utilisée par le journal de détection d'intrusion
// pour "riposter" (bloquer) une source malveillante. Vérifiée à la connexion.
model BlockedIp {
  id        String    @id @default(cuid())
  ip        String    @unique
  reason    String?
  threat    String?   // niveau de menace au moment du blocage (LOW/MEDIUM/HIGH/CRITICAL)
  blockedBy String?   // id de l'admin ayant exécuté la riposte
  active    Boolean   @default(true)
  hits      Int       @default(0) // nombre de requêtes rejetées depuis le blocage
  expiresAt DateTime? // null = blocage permanent
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ip])
  @@index([active])
}

// [IDS] Journal des détections de proxy/VPN/Tor — trafic potentiellement malveillant.
model ProxyDetection {
  id           String   @id @default(cuid())
  ip           String
  isProxy      Boolean  @default(false)
  isVpn        Boolean  @default(false)
  isTor        Boolean  @default(false)
  isDatacenter Boolean  @default(false)
  proxyType    String?  // VPN, TOR, PUB (public proxy), DCH (datacenter)...
  riskScore    Int      @default(0) // 0-100
  country      String?
  countryCode  String?
  isp          String?
  provider     String?
  action       String   @default("LOGGED") // LOGGED | BLOCKED | AUTO_BLOCKED
  context      String?  // login, transfer, withdraw...
  userId       String?
  userAgent    String?
  source       String   @default("api") // api | heuristic
  createdAt    DateTime @default(now())

  @@index([ip])
  @@index([action])
  @@index([createdAt])
  @@index([riskScore])
}

model BankAdmin {
  id        String   @id
  userId    String   @unique
  bankId    String
  role      String   @default("OPERATOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BankAlert {
  id        String   @id
  bankId    String
  type      String
  severity  String   @default("MEDIUM")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BusinessEmployee {
  id         String   @id
  businessId String
  firstName  String
  lastName   String
  position   String?
  salary     Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  avatar     String?
  email      String?
  phone      String?
  userId     String?
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BusinessInvoice {
  id            String   @id
  invoiceNumber String   @unique
  businessId    String
  customerName  String
  total         Float
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Loan {
  id               String        @id @default(cuid())
  reference        String        @unique
  userId           String
  type             LoanType      @default(PERSONAL)
  amount           Float
  interestRate     Float         @default(12.0)
  term             Int
  monthlyPayment   Float
  totalPaid        Float         @default(0)
  remainingBalance Float
  status           LoanStatus    @default(PENDING)
  purpose          String?
  collateral       String?
  guarantorName    String?
  guarantorPhone   String?
  guarantorAddress String?
  creditScore      Int?
  riskLevel        RiskLevel     @default(MEDIUM)
  disbursedAt      DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedReason   String?
  nextPaymentDate  DateTime?
  lastPaymentDate  DateTime?
  missedPayments   Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         LoanPayment[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([reference])
}

model LoanPayment {
  id            String        @id @default(cuid())
  loanId        String
  amount        Float
  principal     Float
  interest      Float
  penalty       Float         @default(0)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  transactionId String?
  createdAt     DateTime      @default(now())
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([dueDate])
}

model SavingsAccount {
  id            String        @id @default(cuid())
  userId        String
  accountNumber String        @unique
  type          SavingsType   @default(REGULAR)
  balance       Float         @default(0)
  interestRate  Float         @default(3.5)
  currency      String        @default("XAF")
  maturityDate  DateTime?
  status        SavingsStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountNumber])
}

model InterestRate {
  id          String   @id @default(cuid())
  type        String
  minRate     Float
  maxRate     Float
  defaultRate Float
  currency    String   @default("XAF")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CreditScore {
  id               String    @id @default(cuid())
  userId           String    @unique
  score            Int       @default(500)
  riskLevel        RiskLevel @default(MEDIUM)
  lastCalculatedAt DateTime  @default(now())
  factors          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemWallet {
  id            String           @id @default(cuid())
  type          SystemWalletType @unique
  name          String
  nameFr        String
  description   String?
  publicAddress String
  privateKey    String?
  balanceUSD    Float            @default(0)
  balancePi     Float            @default(0)
  balanceXAF    Float            @default(0)
  dailyLimit    Float            @default(50000)
  monthlyLimit  Float            @default(500000)
  isLocked      Boolean          @default(false)
  lockReason    String?
  lockedAt      DateTime?
  lockedBy      String?
  lastActivity  DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([type])
  @@index([isLocked])
}


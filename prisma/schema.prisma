generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(cuid())
  phone                String?         @unique
  email                String?         @unique
  username             String?         @unique
  password             String?
  pin                  String?
  refreshToken         String?         @unique
  firstName            String?
  lastName             String?
  name                 String?
  avatar               String?
  country              String?
  city                 String?
  address              String?
  birthDate            DateTime?
  latitude             Float?
  longitude            Float?
  nationality          String?
  idType               String?
  idNumber             String?
  sourceOfFunds        String?
  kycFrontUrl          String?
  kycBackUrl           String?
  kycSelfieUrl         String?
  kycSubmittedAt       DateTime?
  kycVerifiedAt        DateTime?
  kycReason            String?
  referralCode         String?         @unique @default(cuid())
  referredById         String?
  dailyLimit           Float           @default(1000)
  monthlyLimit         Float           @default(10000)
  role                 UserRole        @default(USER)
  kycStatus            KycStatus       @default(NONE)
  status               UserStatus      @default(ACTIVE)
  autoApprove          Boolean         @default(false)
  twoFactorEnabled     Boolean         @default(false)
  twoFactorSecret      String?
  failedLoginAttempts  Int             @default(0)
  lastLoginAt          DateTime?
  lastLoginIp          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  walletAddress        String?         @unique
  piUserId             String?         @unique
  countryOfBirth       String?
  gender               String?
  idCountry            String?
  idDeliveryDate       DateTime?
  idExpiryDate         DateTime?
  lastName2            String?
  middleName           String?
  nativeName           String?
  occupation           String?
  postalCode           String?
  provinceState        String?
  sidraAddress         String?         @unique
  sidraPrivateKey      String?
  stellarPrivateKey    String?
  walletPrivateKey     String?
  xlmAddress           String?         @unique
  xrpAddress           String?         @unique
  xrpPrivateKey        String?
  usdtAddress          String?         @unique
  usdtPrivateKey       String?
  solAddress           String?         @unique
  solPrivateKey        String?
  auditLogs            AuditLog[]      @relation("admin_actions")
  targetLogs           AuditLog[]      @relation("target_user")
  beneficiaries        Beneficiary[]
  merchantProfile      Merchant?       @relation("user_merchant")
  notifications        Notification[]
  p2pContactsAsContact P2PContact[]    @relation("contact_user")
  p2pContactsOwned     P2PContact[]    @relation("contact_owner")
  qrPayments           QRPayment[]
  securityLogs         SecurityLog[]
  sessions             Session[]
  stakings             Staking[]
  supportTickets       SupportTicket[]
  swapQuotes           SwapQuote[]
  transactionsFrom     Transaction[]   @relation("tx_from_user")
  transactionsTo       Transaction[]   @relation("tx_to_user")
  referredBy           User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals            User[]          @relation("Referrals")
  userActivities       UserActivity[]
  vaults               Vault[]
  virtualCards         VirtualCard[]
  wallets              Wallet[]
}

model P2PContact {
  id         String   @id @default(cuid())
  userId     String
  contactId  String
  name       String
  nickname   String?
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  contact    User     @relation("contact_user", fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation("contact_owner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, contactId])
  @@index([userId])
  @@index([isFavorite])
  @@index([contactId])
}

model Wallet {
  id               String        @id @default(cuid())
  userId           String
  balance          Float         @default(0)
  currency         String        @default("XAF")
  type             WalletType    @default(FIAT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  frozenBalance    Float         @default(0)
  depositMemo      String?       @unique
  transactionsFrom Transaction[] @relation("tx_from_wallet")
  transactionsTo   Transaction[] @relation("tx_to_wallet")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
  @@index([depositMemo])
}

model SwapQuote {
  id             String   @id @default(cuid())
  userId         String
  fromAmount     Float
  toAmount       Float
  rate           Float
  targetCurrency String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  sourceCurrency String   @default("USDT")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                 String    @id @default("GLOBAL_CONFIG")
  appVersion         String    @default("2.4.0")
  forceUpdate        Boolean   @default(false)
  globalAnnouncement String?
  maintenanceMode    Boolean   @default(false)
  maintenanceUntil   DateTime?
  transactionFee     Float     @default(0.01)
  minWithdrawal      Float     @default(1.0)
  maxWithdrawal      Float     @default(5000.0)
  consensusPrice     Float     @default(314159.0)
  stakingAPY         Float     @default(15.0)
  totalProfit        Float     @default(0.0)
  updatedAt          DateTime  @updatedAt
  lastBackupAt       DateTime  @default(now())
  totalUsers         Int       @default(0)
  totalVolumePi      Float     @default(0.0)
  comingSoonMode     Boolean   @default(false)
  withdrawFee        Float     @default(0.02)
  depositMobileFee   Float     @default(0.02)
  depositCardFee     Float     @default(0.035)
  exchangeFee        Float     @default(0.001)
  cardPaymentFee     Float     @default(0.015)
  transferFee        Float     @default(0.01)
  depositCryptoFee   Float     @default(0.01)
  withdrawMobileFee  Float     @default(0.025)
  withdrawBankFee    Float     @default(0.02)
  merchantPaymentFee Float     @default(0.02)
  billPaymentFee     Float     @default(0.015)
  qrPaymentFee       Float     @default(0.01)
}

model DailyStats {
  id             String   @id @default(cuid())
  date           DateTime @unique @default(now())
  totalUsers     Int      @default(0)
  totalVolume    Float    @default(0.0)
  consensusPrice Float    @default(0.0)
  stakingAPY     Float    @default(0.0)
  activeUsers    Int      @default(0)
}

model Vault {
  id           String    @id @default(cuid())
  userId       String
  name         String
  amount       Float     @default(0)
  targetAmount Float?
  interestRate Float     @default(0)
  lockUntil    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Staking {
  id            String    @id @default(cuid())
  userId        String
  amount        Float
  apy           Float
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)
  rewardsEarned Float     @default(0)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Beneficiary {
  id           String   @id @default(cuid())
  userId       String
  name         String
  accountInfo  String
  provider     String
  createdAt    DateTime @default(now())
  email        String?
  firstname    String?
  lastname     String?
  msisdn       String?
  relationship String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(cuid())
  reference       String            @unique
  blockchainTx    String?           @unique
  amount          Float
  fee             Float             @default(0)
  netAmount       Float?
  status          TransactionStatus @default(PENDING)
  description     String?
  note            String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  fromUserId      String?
  fromWalletId    String?
  toUserId        String?
  toWalletId      String?
  qrPaymentId     String?
  accountName     String?
  accountNumber   String?
  bankBic         String?
  countryCode     String?
  currency        String            @default("XAF")
  destCurrency    String?
  externalId      String?           @unique
  operatorId      String?
  purpose         String?
  retailFee       Float?
  retailRate      Float?
  statusClass     String?
  wholesaleFxRate Float?
  type            TransactionType   @default(TRANSFER)
  fromUser        User?             @relation("tx_from_user", fields: [fromUserId], references: [id])
  fromWallet      Wallet?           @relation("tx_from_wallet", fields: [fromWalletId], references: [id])
  qrPayment       QRPayment?        @relation(fields: [qrPaymentId], references: [id])
  toUser          User?             @relation("tx_to_user", fields: [toUserId], references: [id])
  toWallet        Wallet?           @relation("tx_to_wallet", fields: [toWalletId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
  @@index([reference])
  @@index([externalId])
}

model Merchant {
  id              String   @id @default(cuid())
  userId          String?  @unique
  name            String
  description     String?
  category        String
  address         String
  city            String
  country         String
  latitude        Float
  longitude       Float
  piPaymentStatus String   @default("ACCEPTED")
  rating          Float    @default(0.0)
  logoUrl         String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation("user_merchant", fields: [userId], references: [id])
}

model VirtualCard {
  id                String   @id @default(cuid())
  userId            String
  type              CardType @default(CLASSIC)
  number            String   @unique
  exp               String
  cvv               String?
  holder            String
  brand             String   @default("VISA")
  cardPin           String?
  isFrozen          Boolean  @default(false)
  dailyLimit        Float    @default(1000)
  totalSpent        Float    @default(0)
  allowedCurrencies String[] @default(["USD", "XAF"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QRPayment {
  id           String        @id @default(cuid())
  userId       String
  amount       Float?
  currency     String        @default("XAF")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ip           String?
  userAgent    String?
  deviceName   String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  browser      String?
  city         String?
  country      String?
  lat          Float?
  lon          Float?
  os           String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Otp {
  id         String   @id @default(cuid())
  identifier String
  code       String
  type       String   @default("VERIFICATION")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  adminName   String?
  action      String
  targetId    String?
  targetEmail String?
  details     String?
  createdAt   DateTime @default(now())
  admin       User?    @relation("admin_actions", fields: [adminId], references: [id])
  target      User?    @relation("target_user", fields: [targetId], references: [id])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ip        String?
  device    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  page      String
  action    String   @default("PAGE_VIEW")
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  duration  Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([page])
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String?
  subject   String
  status    SupportStatus @default(OPEN)
  priority  String        @default("MEDIUM")
  createdAt DateTime      @default(now())
  messages  Message[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Bank {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  type        BankType    @default(COMMERCIAL_BANK)
  status      BankStatus  @default(PENDING_APPROVAL)
  email       String?
  country     String      @default("CG")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  city        String?
  description String?
  address     String?
  phone       String?
  logo        String?
  BankAdmin   BankAdmin[]
  BankAlert   BankAlert[]
}

model Business {
  id                 String             @id @default(cuid())
  name               String
  registrationNumber String             @unique
  type               BusinessType       @default(SOLE_PROPRIETORSHIP)
  category           BusinessCategory   @default(OTHER)
  status             BusinessStatus     @default(PENDING_VERIFICATION)
  country            String             @default("CG")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  city               String?
  description        String?
  email              String?
  phone              String?
  logo               String?
  BusinessEmployee   BusinessEmployee[]
  BusinessInvoice    BusinessInvoice[]
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  source    String
  action    String
  message   String
  details   Json?
  ip        String?
  userAgent String?
  userId    String?
  requestId String?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([userId])
}

model BankAdmin {
  id        String   @id
  userId    String   @unique
  bankId    String
  role      String   @default("OPERATOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BankAlert {
  id        String   @id
  bankId    String
  type      String
  severity  String   @default("MEDIUM")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BusinessEmployee {
  id         String   @id
  businessId String
  firstName  String
  lastName   String
  position   String?
  salary     Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BusinessInvoice {
  id            String   @id
  invoiceNumber String   @unique
  businessId    String
  customerName  String
  total         Float
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum CardType {
  CLASSIC
  GOLD
  BUSINESS
  ULTRA
}

enum UserRole {
  ADMIN
  USER
  MERCHANT
  AGENT
  BANK_ADMIN
  BUSINESS_ADMIN
}

enum BankStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
  INACTIVE
}

enum BankType {
  CENTRAL_BANK
  COMMERCIAL_BANK
  MICROFINANCE
  CREDIT_UNION
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  INACTIVE
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  LLC
  COOPERATIVE
  NGO
}

enum BusinessCategory {
  RETAIL
  WHOLESALE
  SERVICES
  MANUFACTURING
  TECHNOLOGY
  HOSPITALITY
  HEALTHCARE
  EDUCATION
  TRANSPORT
  AGRICULTURE
  OTHER
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
  FROZEN
  SUSPENDED
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
  APPROVED
}

enum WalletType {
  PI
  FIAT
  CRYPTO
  SIDRA
}

enum TransactionType {
  TRANSFER
  WITHDRAW
  DEPOSIT
  PAYMENT
  EXCHANGE
  STAKING_REWARD
  AIRDROP
  CARD_PURCHASE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

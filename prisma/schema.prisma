  page      String
  action    String   @default("PAGE_VIEW")
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  duration  Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([page])
  @@map("user_activities")
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String?
  subject   String
  status    SupportStatus @default(OPEN)
  priority  String        @default("MEDIUM")
  createdAt DateTime      @default(now())
  messages  Message[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model Message {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Bank {
  id          String      @id @default(cuid())
  name        String      @unique
  code        String      @unique
  type        BankType    @default(COMMERCIAL_BANK)
  status      BankStatus  @default(PENDING_APPROVAL)
  email       String?
  country     String      @default("CG")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  city        String?
  description String?
  address     String?
  phone       String?
  logo        String?
  BankAdmin   BankAdmin[]
  BankAlert   BankAlert[]

  @@map("banks")
}

model Business {
  id                 String             @id @default(cuid())
  name               String
  registrationNumber String             @unique
  type               BusinessType       @default(SOLE_PROPRIETORSHIP)
  category           BusinessCategory   @default(OTHER)
  status             BusinessStatus     @default(PENDING_VERIFICATION)
  country            String             @default("CG")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  city               String?
  description        String?
  email              String?
  phone              String?
  logo               String?
  BusinessEmployee   BusinessEmployee[]
  BusinessInvoice    BusinessInvoice[]

  @@map("businesses")
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel @default(INFO)
  source    String
  action    String
  message   String
  details   Json?
  ip        String?
  userAgent String?
  userId    String?
  requestId String?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([userId])
  @@map("system_logs")
}

model BankAdmin {
  id        String   @id
  userId    String   @unique
  bankId    String
  role      String   @default("OPERATOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("bank_admins")
}

model BankAlert {
  id        String   @id
  bankId    String
  type      String
  severity  String   @default("MEDIUM")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("bank_alerts")
}

model BusinessEmployee {
  id         String   @id
  businessId String
  firstName  String
  lastName   String
  position   String?
  salary     Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  avatar     String?
  email      String?
  phone      String?
  userId     String?
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("business_employees")
}

model BusinessInvoice {
  id            String   @id
  invoiceNumber String   @unique
  businessId    String
  customerName  String
  total         Float
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("business_invoices")
}

model Loan {
  id               String        @id @default(cuid())
  reference        String        @unique
  userId           String
  type             LoanType      @default(PERSONAL)
  amount           Float
  interestRate     Float         @default(12.0)
  term             Int
  monthlyPayment   Float
  totalPaid        Float         @default(0)
  remainingBalance Float
  status           LoanStatus    @default(PENDING)
  purpose          String?
  collateral       String?
  guarantorName    String?
  guarantorPhone   String?
  guarantorAddress String?
  creditScore      Int?
  riskLevel        RiskLevel     @default(MEDIUM)
  disbursedAt      DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedReason   String?
  nextPaymentDate  DateTime?
  lastPaymentDate  DateTime?
  missedPayments   Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         LoanPayment[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([reference])
  @@map("loans")
}

model LoanPayment {
  id            String        @id @default(cuid())
  loanId        String
  amount        Float
  principal     Float
  interest      Float
  penalty       Float         @default(0)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  transactionId String?
  createdAt     DateTime      @default(now())
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([dueDate])
  @@map("loan_payments")
}

model SavingsAccount {
  id            String        @id @default(cuid())
  userId        String
  accountNumber String        @unique
  type          SavingsType   @default(REGULAR)
  balance       Float         @default(0)
  interestRate  Float         @default(3.5)
  currency      String        @default("XAF")
  maturityDate  DateTime?
  status        SavingsStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountNumber])
  @@map("savings_accounts")
}

model InterestRate {
  id          String   @id @default(cuid())
  type        String
  minRate     Float
  maxRate     Float
  defaultRate Float
  currency    String   @default("XAF")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("interest_rates")
}

model CreditScore {
  id               String    @id @default(cuid())
  userId           String    @unique
  score            Int       @default(500)
  riskLevel        RiskLevel @default(MEDIUM)
  lastCalculatedAt DateTime  @default(now())
  factors          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_scores")
}

enum BankStatus {
  ACTIVE
  SUSPENDED
  PENDING_APPROVAL
  INACTIVE
// ─────────────────────────────────────────────
// ISO20022 & BANKING MODELS
// ─────────────────────────────────────────────

model ISO20022Message {
  id                 String                @id @default(cuid())
  messageId          String                @unique
  messageType        ISO20022MessageType
  messageStatus      ISO20022MessageStatus @default(RECEIVED)
  paymentType        PaymentType?
  senderBic          String?
  receiverBic        String?
  creationDateTime   DateTime
  settlementDate     DateTime?
  totalAmount        Decimal               @db.Decimal(20, 8)
  currency           CurrencyType
  numberOfTxns       Int                   @default(0)
  rawPayload         Json
  validationErrors   Json?
  processedAt        DateTime?
  settledAt          DateTime?
  rejectionReason    String?
  correlationId      String?
  instructionId      String?
  endToEndId         String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  paymentTransactions PaymentTransaction[]

  @@index([messageType])
  @@index([messageStatus])
  @@index([creationDateTime])
  @@index([senderBic])
  @@index([receiverBic])
  @@index([settlementDate])
  @@map("iso20022_messages")
}

enum BankType {
  CENTRAL_BANK
  COMMERCIAL_BANK
  MICROFINANCE
  CREDIT_UNION
}

enum BusinessCategory {
  RETAIL
  WHOLESALE
  SERVICES
  MANUFACTURING
  TECHNOLOGY
  HOSPITALITY
  HEALTHCARE
  EDUCATION
  TRANSPORT
  AGRICULTURE
  OTHER
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  INACTIVE
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  CORPORATION
  LLC
  COOPERATIVE
  NGO
}

enum LoanStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  ACTIVE
  COMPLETED
  DEFAULTED
  REJECTED
  CANCELLED
}

enum LoanType {
  PERSONAL
  BUSINESS
  MORTGAGE
  AUTO
  EDUCATION
  AGRICULTURE
  EMERGENCY
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum PaymentStatus {
  PENDING
  PAID
  LATE
  MISSED
  PARTIAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum SavingsStatus {
  ACTIVE
  MATURED
  CLOSED
  FROZEN
}

enum SavingsType {
  REGULAR
  FIXED_DEPOSIT
  RECURRING
  GOAL_BASED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum WalletType {

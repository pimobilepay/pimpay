generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id                           String   @id
  adminId                      String?
  adminName                    String?
  action                       String
  targetId                     String?
  targetEmail                  String?
  details                      String?
  createdAt                    DateTime @default(now())
  User_AuditLog_adminIdToUser  User?    @relation("AuditLog_adminIdToUser", fields: [adminId], references: [id])
  User_AuditLog_targetIdToUser User?    @relation("AuditLog_targetIdToUser", fields: [targetId], references: [id])
}

model Bank {
  id          String      @id
  name        String      @unique
  code        String      @unique
  type        BankType    @default(COMMERCIAL_BANK)
  status      BankStatus  @default(PENDING_APPROVAL)
  email       String?
  country     String      @default("CG")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
  city        String?
  description String?
  address     String?
  phone       String?
  logo        String?
  BankAdmin   BankAdmin[]
  BankAlert   BankAlert[]
}

model BankAdmin {
  id        String   @id
  userId    String   @unique
  bankId    String
  role      String   @default("OPERATOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BankAlert {
  id        String   @id
  bankId    String
  type      String
  severity  String   @default("MEDIUM")
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  Bank      Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Beneficiary {
  id           String   @id
  userId       String
  name         String
  accountInfo  String
  provider     String
  createdAt    DateTime @default(now())
  email        String?
  firstname    String?
  lastname     String?
  msisdn       String?
  relationship String?
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Business {
  id                 String             @id
  name               String
  registrationNumber String             @unique
  type               BusinessType       @default(SOLE_PROPRIETORSHIP)
  category           BusinessCategory   @default(OTHER)
  status             BusinessStatus     @default(PENDING_VERIFICATION)
  country            String             @default("CG")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now())
  city               String?
  description        String?
  email              String?
  phone              String?
  logo               String?
  BusinessEmployee   BusinessEmployee[]
  BusinessInvoice    BusinessInvoice[]
}

model BusinessEmployee {
  id         String   @id
  businessId String
  firstName  String
  lastName   String
  position   String?
  salary     Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  avatar     String?
  email      String?
  phone      String?
  userId     String?
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BusinessInvoice {
  id            String   @id
  invoiceNumber String   @unique
  businessId    String
  customerName  String
  total         Float
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())
  Business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model CreditScore {
  id               String    @id
  userId           String    @unique
  score            Int       @default(500)
  riskLevel        RiskLevel @default(MEDIUM)
  lastCalculatedAt DateTime  @default(now())
  factors          Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  User             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyStats {
  id             String   @id
  date           DateTime @unique @default(now())
  totalUsers     Int      @default(0)
  totalVolume    Float    @default(0.0)
  consensusPrice Float    @default(0.0)
  stakingAPY     Float    @default(0.0)
  activeUsers    Int      @default(0)
}

model InterestRate {
  id          String   @id
  type        String
  minRate     Float
  maxRate     Float
  defaultRate Float
  currency    String   @default("XAF")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Loan {
  id               String        @id
  reference        String        @unique
  userId           String
  type             LoanType      @default(PERSONAL)
  amount           Float
  interestRate     Float         @default(12.0)
  term             Int
  monthlyPayment   Float
  totalPaid        Float         @default(0)
  remainingBalance Float
  status           LoanStatus    @default(PENDING)
  purpose          String?
  collateral       String?
  guarantorName    String?
  guarantorPhone   String?
  guarantorAddress String?
  creditScore      Int?
  riskLevel        RiskLevel     @default(MEDIUM)
  disbursedAt      DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedReason   String?
  nextPaymentDate  DateTime?
  lastPaymentDate  DateTime?
  missedPayments   Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  User             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  LoanPayment      LoanPayment[]

  @@index([reference])
  @@index([status])
  @@index([type])
  @@index([userId])
}

model LoanPayment {
  id            String        @id
  loanId        String
  amount        Float
  principal     Float
  interest      Float
  penalty       Float         @default(0)
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  transactionId String?
  createdAt     DateTime      @default(now())
  Loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([loanId])
}

model Merchant {
  id              String   @id
  userId          String?  @unique
  name            String
  description     String?
  category        String
  address         String
  city            String
  country         String
  latitude        Float
  longitude       Float
  piPaymentStatus String   @default("ACCEPTED")
  rating          Float    @default(0.0)
  logoUrl         String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  User            User?    @relation(fields: [userId], references: [id])
}

model Message {
  id            String        @id
  ticketId      String
  senderId      String
  content       String
  createdAt     DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model Otp {
  id         String   @id
  identifier String
  code       String
  type       String   @default("VERIFICATION")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model P2PContact {
  id                              String   @id
  userId                          String
  contactId                       String
  name                            String
  nickname                        String?
  isFavorite                      Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @default(now())
  User_P2PContact_contactIdToUser User     @relation("P2PContact_contactIdToUser", fields: [contactId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User_P2PContact_userIdToUser    User     @relation("P2PContact_userIdToUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, contactId])
  @@index([contactId])
  @@index([isFavorite])
  @@index([userId])
}

model QRPayment {
  id          String        @id
  userId      String
  amount      Float?
  currency    String        @default("XAF")
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Transaction Transaction[]
}

model SavingsAccount {
  id            String        @id
  userId        String
  accountNumber String        @unique
  type          SavingsType   @default(REGULAR)
  balance       Float         @default(0)
  interestRate  Float         @default(3.5)
  currency      String        @default("XAF")
  maturityDate  DateTime?
  status        SavingsStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  User          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountNumber])
  @@index([userId])
}

model SecurityLog {
  id        String   @id
  userId    String
  action    String
  ip        String?
  device    String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id
  userId       String
  token        String   @unique
  ip           String?
  userAgent    String?
  deviceName   String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  browser      String?
  city         String?
  country      String?
  lat          Float?
  lon          Float?
  os           String?
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Staking {
  id            String    @id
  userId        String
  amount        Float
  apy           Float
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)
  rewardsEarned Float     @default(0)
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String        @id
  userId    String?
  subject   String
  status    SupportStatus @default(OPEN)
  priority  String        @default("MEDIUM")
  createdAt DateTime      @default(now())
  Message   Message[]
  User      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SwapQuote {
  id             String   @id
  userId         String
  fromAmount     Float
  toAmount       Float
  rate           Float
  targetCurrency String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  sourceCurrency String   @default("USDT")
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                 String    @id @default("GLOBAL_CONFIG")
  appVersion         String    @default("2.4.0")
  forceUpdate        Boolean   @default(false)
  globalAnnouncement String?
  maintenanceMode    Boolean   @default(false)
  maintenanceUntil   DateTime?
  transactionFee     Float     @default(0.01)
  minWithdrawal      Float     @default(1.0)
  maxWithdrawal      Float     @default(5000.0)
  consensusPrice     Float     @default(314159.0)
  stakingAPY         Float     @default(15.0)
  totalProfit        Float     @default(0.0)
  updatedAt          DateTime
  lastBackupAt       DateTime  @default(now())
  totalUsers         Int       @default(0)
  totalVolumePi      Float     @default(0.0)
  comingSoonMode     Boolean   @default(false)
  withdrawFee        Float     @default(0.02)
  depositMobileFee   Float     @default(0.02)
  depositCardFee     Float     @default(0.035)
  exchangeFee        Float     @default(0.001)
  cardPaymentFee     Float     @default(0.015)
  transferFee        Float     @default(0.01)
  depositCryptoFee   Float     @default(0.01)
  withdrawMobileFee  Float     @default(0.025)
  withdrawBankFee    Float     @default(0.02)
  merchantPaymentFee Float     @default(0.02)
  billPaymentFee     Float     @default(0.015)
  qrPaymentFee       Float     @default(0.01)
}

model SystemLog {
  id        String   @id
  level     LogLevel @default(INFO)
  source    String
  action    String
  message   String
  details   Json?
  ip        String?
  userAgent String?
  userId    String?
  requestId String?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
  @@index([source])
  @@index([userId])
}

model Transaction {
  id                                      String            @id
  reference                               String            @unique
  blockchainTx                            String?           @unique
  amount                                  Float
  fee                                     Float             @default(0)
  netAmount                               Float?
  status                                  TransactionStatus @default(PENDING)
  description                             String?
  note                                    String?
  metadata                                Json?
  createdAt                               DateTime          @default(now())
  fromUserId                              String?
  fromWalletId                            String?
  toUserId                                String?
  toWalletId                              String?
  qrPaymentId                             String?
  accountName                             String?
  accountNumber                           String?
  bankBic                                 String?
  countryCode                             String?
  currency                                String            @default("XAF")
  destCurrency                            String?
  externalId                              String?           @unique
  operatorId                              String?
  purpose                                 String?
  retailFee                               Float?
  retailRate                              Float?
  statusClass                             String?
  wholesaleFxRate                         Float?
  type                                    TransactionType   @default(TRANSFER)
  User_Transaction_fromUserIdToUser       User?             @relation("Transaction_fromUserIdToUser", fields: [fromUserId], references: [id])
  Wallet_Transaction_fromWalletIdToWallet Wallet?           @relation("Transaction_fromWalletIdToWallet", fields: [fromWalletId], references: [id])
  QRPayment                               QRPayment?        @relation(fields: [qrPaymentId], references: [id])
  User_Transaction_toUserIdToUser         User?             @relation("Transaction_toUserIdToUser", fields: [toUserId], references: [id])
  Wallet_Transaction_toWalletIdToWallet   Wallet?           @relation("Transaction_toWalletIdToWallet", fields: [toWalletId], references: [id])

  @@index([externalId])
  @@index([fromUserId])
  @@index([reference])
  @@index([toUserId])
}

model User {
  id                                       String           @id
  phone                                    String?          @unique
  email                                    String?          @unique
  username                                 String?          @unique
  password                                 String?
  pin                                      String?
  refreshToken                             String?          @unique
  firstName                                String?
  lastName                                 String?
  name                                     String?
  avatar                                   String?
  country                                  String?
  city                                     String?
  address                                  String?
  birthDate                                DateTime?
  latitude                                 Float?
  longitude                                Float?
  nationality                              String?
  idType                                   String?
  idNumber                                 String?
  sourceOfFunds                            String?
  kycFrontUrl                              String?
  kycBackUrl                               String?
  kycSelfieUrl                             String?
  kycSubmittedAt                           DateTime?
  kycVerifiedAt                            DateTime?
  kycReason                                String?
  referralCode                             String?          @unique
  referredById                             String?
  dailyLimit                               Float            @default(1000)
  monthlyLimit                             Float            @default(10000)
  role                                     UserRole         @default(USER)
  kycStatus                                KycStatus        @default(NONE)
  status                                   UserStatus       @default(ACTIVE)
  autoApprove                              Boolean          @default(false)
  twoFactorEnabled                         Boolean          @default(false)
  twoFactorSecret                          String?
  failedLoginAttempts                      Int              @default(0)
  lastLoginAt                              DateTime?
  lastLoginIp                              String?
  createdAt                                DateTime         @default(now())
  updatedAt                                DateTime
  walletAddress                            String?          @unique
  piUserId                                 String?          @unique
  countryOfBirth                           String?
  gender                                   String?
  idCountry                                String?
  idDeliveryDate                           DateTime?
  idExpiryDate                             DateTime?
  lastName2                                String?
  middleName                               String?
  nativeName                               String?
  occupation                               String?
  postalCode                               String?
  provinceState                            String?
  sidraAddress                             String?          @unique
  sidraPrivateKey                          String?
  stellarPrivateKey                        String?
  walletPrivateKey                         String?
  xlmAddress                               String?          @unique
  xrpAddress                               String?          @unique
  xrpPrivateKey                            String?
  usdtAddress                              String?          @unique
  usdtPrivateKey                           String?
  solAddress                               String?          @unique
  solPrivateKey                            String?
  AuditLog_AuditLog_adminIdToUser          AuditLog[]       @relation("AuditLog_adminIdToUser")
  AuditLog_AuditLog_targetIdToUser         AuditLog[]       @relation("AuditLog_targetIdToUser")
  Beneficiary                              Beneficiary[]
  CreditScore                              CreditScore?
  Loan                                     Loan[]
  Merchant                                 Merchant?
  Notification                             Notification[]
  P2PContact_P2PContact_contactIdToUser    P2PContact[]     @relation("P2PContact_contactIdToUser")
  P2PContact_P2PContact_userIdToUser       P2PContact[]     @relation("P2PContact_userIdToUser")
  QRPayment                                QRPayment[]
  SavingsAccount                           SavingsAccount[]
  SecurityLog                              SecurityLog[]
  Session                                  Session[]
  Staking                                  Staking[]
  SupportTicket                            SupportTicket[]
  SwapQuote                                SwapQuote[]
  Transaction_Transaction_fromUserIdToUser Transaction[]    @relation("Transaction_fromUserIdToUser")
  Transaction_Transaction_toUserIdToUser   Transaction[]    @relation("Transaction_toUserIdToUser")
  User                                     User?            @relation("UserToUser", fields: [referredById], references: [id])
  other_User                               User[]           @relation("UserToUser")
  UserActivity                             UserActivity[]
  Vault                                    Vault[]
  VirtualCard                              VirtualCard[]
  Wallet                                   Wallet[]
}

model UserActivity {
  id        String   @id
  userId    String
  page      String
  action    String   @default("PAGE_VIEW")
  ip        String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  duration  Int?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([page])
  @@index([userId])
}

model Vault {
  id           String    @id
  userId       String
  name         String
  amount       Float     @default(0)
  targetAmount Float?
  interestRate Float     @default(0)
  lockUntil    DateTime?
  createdAt    DateTime  @default(now())
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VirtualCard {
  id                String   @id
  userId            String
  type              CardType @default(CLASSIC)
  number            String   @unique
  exp               String
  cvv               String?
  holder            String
  brand             String   @default("VISA")
  cardPin           String?
  isFrozen          Boolean  @default(false)
  dailyLimit        Float    @default(1000)
  totalSpent        Float    @default(0)
  allowedCurrencies String[] @default(["USD", "XAF"])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                                           String        @id
  userId                                       String
  balance                                      Float         @default(0)
  currency                                     String        @default("XAF")
  type                                         WalletType    @default(FIAT)
  createdAt                                    DateTime      @default(now())
  updatedAt                                    DateTime
  frozenBalance                                Float         @default(0)
  depositMemo                                  String?       @unique
  Transaction_Transaction_fromWalletIdToWallet Transaction[] @relation("Transaction_fromWalletIdToWallet")
  Transaction_Transaction_toWalletIdToWallet   Transaction[] @relation("Transaction_toWalletIdToWallet")
  User                                         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([depositMemo])
  @@index([userId])
}
// ─────────────────────────────────────────────

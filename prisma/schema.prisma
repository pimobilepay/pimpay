  BIZZ
  SVGS
  EWLT
  CWLT
  PIWT
  NSVR
}

enum ISO20022MessageType {
  PACS_008
  PACS_002
  PACS_004
  PACS_009
  PAIN_001
  PAIN_002
  CAMT_052
  CAMT_053
  CAMT_054
}

enum ISO20022MessageStatus {
  RECEIVED
  VALIDATED

model Wallet {
  id            String       @id @default(cuid())
  userId        String
  currency      CurrencyType @default(XAF)
  balance       Decimal      @default(0) @db.Decimal(20, 8)
  lockedBalance Decimal      @default(0) @db.Decimal(20, 8)
  frozenBalance Decimal      @default(0) @db.Decimal(20, 8)
  isActive      Boolean      @default(true)
  address       String?      @unique
  type          WalletType   @default(FIAT)
  depositMemo   String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("SenderWallet")
  receivedTransactions Transaction[] @relation("ReceiverWallet")

  @@unique([userId, currency])
  @@index([userId])
  @@index([currency])
  @@index([depositMemo])
  @@map("wallets")
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  senderWalletId    String?
  receiverWalletId  String?
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  amount            Decimal           @db.Decimal(20, 8)
  fee               Decimal           @default(0) @db.Decimal(20, 8)
  netAmount         Decimal?          @db.Decimal(20, 8)
  currency          CurrencyType
  description       String?
  note              String?
  reference         String?           @unique
  blockchainTx      String?           @unique
  externalId        String?           @unique
  metadata          Json?
  ipAddress         String?
  deviceId          String?
  failureReason     String?
  processedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  qrPaymentId       String?
  accountName       String?
  accountNumber     String?
  bankBic           String?
  countryCode       String?
  destCurrency      String?
  operatorId        String?
  purpose           String?
  retailFee         Decimal?          @db.Decimal(20, 8)
  retailRate        Decimal?          @db.Decimal(20, 8)
  statusClass       String?
  wholesaleFxRate   Decimal?          @db.Decimal(20, 8)
  user              User              @relation(fields: [userId], references: [id])
  senderWallet      Wallet?           @relation("SenderWallet", fields: [senderWalletId], references: [id])
  receiverWallet    Wallet?           @relation("ReceiverWallet", fields: [receiverWalletId], references: [id])
  qrPayment         QRPayment?        @relation(fields: [qrPaymentId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([reference])
  @@index([externalId])
  @@map("transactions")
}


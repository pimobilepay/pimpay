  FI_TRANSFER
  DIRECT_DEBIT
}

enum TransactionPriority {
  HIGH
  NORMAL
  LOW
}

enum ComplianceStatus {
  CLEAR
  FLAGGED
  BLOCKED
  UNDER_REVIEW

/**
 * .env.local.example
 * Local development environment variables
 * DO NOT commit this file - use .env.local instead
 */

# Database (local PostgreSQL)
DATABASE_URL=postgresql://pimpay:password@localhost:5432/pimpay_dev

# Auth
JWT_SECRET=dev-secret-key-at-least-32-characters-long-please!!!!
JWT_REFRESH_SECRET=dev-refresh-secret-key-at-least-32-characters!!!!

# Encryption
ENCRYPTION_KEY=dev-encryption-key-at-least-32-chars-long!!!!

# CSRF
CSRF_SECRET=dev-csrf-secret-key-at-least-32-characters-long!!!!

# Redis (local)
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local-token

# Firebase (dev project)
FIREBASE_API_KEY=AIzaSyDxxx...
FIREBASE_AUTH_DOMAIN=pimpay-dev.firebaseapp.com
FIREBASE_PROJECT_ID=pimpay-dev
FIREBASE_STORAGE_BUCKET=pimpay-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=12345678
FIREBASE_APP_ID=1:12345678:web:abcdef123456

# Blockchain RPC (testnet)
SIDRA_RPC=https://testnet.sidrachain.com
XRP_RPC=https://testnet.xrpl.example.com

# APIs
PROXYCHECK_API_KEY=your-dev-key
CLOUDINARY_URL=cloudinary://key:secret@cloud-name
GOOGLE_GENAI_API_KEY=your-dev-key

# Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
